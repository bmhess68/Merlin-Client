# Copy to .env and edit. Compose reads it automatically.
# All operational config (cameras, cloud, recording) lives in data/config.json
# and is managed by the installer UI at :8080. This file holds install-time
# secrets and a few non-camera knobs.

# Installer UI basic auth. Leave blank to disable auth (fine if access is gated
# at the network layer by Tailscale + LAN).
# ADMIN_PASSWORD=
# ADMIN_USERNAME=admin

# Tailscale: paste a reusable auth key from
# https://login.tailscale.com/admin/settings/keys to skip the bootstrap prompt.
# TAILSCALE_AUTH_KEY=tskey-auth-...
# TAILSCALE_HOSTNAME=merlin-edge-mysite

# install.sh source-of-truth (set when curl|bash bootstrapping a fresh machine)
# MERLIN_REPO=https://github.com/<org>/videoclient.git
# MERLIN_BRANCH=main
# MERLIN_DIR=/opt/merlin-edge

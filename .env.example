# Copy to .env and edit. Compose reads it automatically.
# All operational config (cameras, cloud, recording) lives in data/config.json
# and is managed by the installer UI at :8080. This file holds install-time
# secrets and a few non-camera knobs.

# Installer UI basic auth. Leave blank to disable auth (fine if access is gated
# at the network layer by Tailscale + LAN).
# ADMIN_PASSWORD=
# ADMIN_USERNAME=admin

# Shared password for the cloud Caddy → mediamtx playback proxy.
# Must match the password the Merlin web app / cloud Caddy passes via
# HTTP Basic auth as user "merlinread". Without this, the playback
# server still starts but no client can authenticate against it.
# MERLINREAD_PASSWORD=

# Control-plane API key for posting camera registrations to the cloud's
# /api/v1/admin/cloud-pull-cameras endpoint. Cloud is master — it owns
# mediamtx path generation. This key is sent as the `x-api-key` header
# on every save and on Sync-cloud-now button. Without this, the box
# logs "skipped: CONTROL_API_KEY env var is not set" on every save and
# no registration reaches the cloud.
# CONTROL_API_KEY=

# Tailscale: paste a reusable auth key from
# https://login.tailscale.com/admin/settings/keys to skip the bootstrap prompt.
# TAILSCALE_AUTH_KEY=tskey-auth-...
# TAILSCALE_HOSTNAME=merlin-edge-mysite

# install.sh source-of-truth (set when curl|bash bootstrapping a fresh machine)
# MERLIN_REPO=https://github.com/<org>/videoclient.git
# MERLIN_BRANCH=main
# MERLIN_DIR=/opt/merlin-edge
